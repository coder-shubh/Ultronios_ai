{
  "name": "rn-ai-agent-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop shell for Ultronios (loads the web UI)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "wait-on http://127.0.0.1:3001 && electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.ultronios.agent",
    "productName": "Ultronios",
    "files": [
      "main.js",
      "preload.cjs",
      "assets/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ],
      "artifactName": "Ultronios-desktop.${ext}"
    },
    "dmg": {
      "artifactName": "Ultronios-desktop.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Ultronios-desktop.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  }
}
