# Required — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY='your-anthropic-api-key'

# Optional: protect /api/agent (send header x-agent-token)
# AGENT_API_TOKEN=

# ─── Ollama — free, runs locally ──────────────────────────────────────────────
# Install: https://ollama.com
#
# Ultronios uses TWO Ollama models:
#   OLLAMA_CODER_MODEL — for write/debug tasks (larger, smarter for code)
#   OLLAMA_CHAT_MODEL  — for read/run tasks    (faster, cheaper for Q&A)
#
# Recommended setup:
#   ollama pull qwen2.5-coder:7b   ← coder model (~4.5 GB)
#   ollama pull llama3.2           ← chat model  (~2 GB)
#
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_CODER_MODEL=qwen2.5-coder:7b
# OLLAMA_CHAT_MODEL=llama3.2
#
# Override both with a single model (disables per-intent routing):
# OLLAMA_MODEL=qwen2.5-coder:7b
#
# OLLAMA_TOOLS=1
# OLLAMA_AGENT_MAX_TURNS=16
# OLLAMA_TEMPERATURE=0.1
# OLLAMA_NUM_CTX=16384
# OLLAMA_DISABLED=1

# ─── Google Gemini — free tier ────────────────────────────────────────────────
# Get key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ─── Groq — free tier ─────────────────────────────────────────────────────────
# Get key: https://console.groq.com
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant

# ─── Fallback behaviour ───────────────────────────────────────────────────────
# FALLBACK_ORDER=ollama,gemini,groq
# FALLBACK_TIMEOUT_MS=120000
# FALLBACK_VERBOSE_BANNER=1
