# Required — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY='your-anthropic-api-key'

# Netlify / Vercel: the app uses the Anthropic Messages API (no Claude Code CLI). Optional:
# ANTHROPIC_MODEL_READ=claude-3-5-haiku-20241022
# ANTHROPIC_MODEL_WRITE=claude-sonnet-4-20250514
# Local: use Claude Agent SDK with tools (set USE_CLAUDE_AGENT_SDK=1 to force it even on Netlify).

# ─── Web (Next.js) — add to web/.env.local when running the web app ──────────
# Desktop installers are served via /api/desktop-download?os=mac|win (not raw /downloads/… links).
# If you set an https URL below, the API redirects there (avoids downloading HTML error pages).
# For local files, put builds in web/public/downloads/ (default names below) or set a /path under public.
# Optional legacy: same URL for both platforms if you do not set MAC/WIN.
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_URL=https://example.com/Ultronios-universal.dmg
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_URL_MAC=https://github.com/your-org/your-repo/releases/download/v1.0.0/Ultronios-mac.dmg
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_URL_WIN=https://github.com/your-org/your-repo/releases/download/v1.0.0/Ultronios-setup.exe

# Optional: protect /api/agent (send header x-agent-token)
# AGENT_API_TOKEN=

# ─── Ollama — free, runs locally ──────────────────────────────────────────────
# Install: https://ollama.com
#
# Ultronios uses TWO Ollama models:
#   OLLAMA_CODER_MODEL — for write/debug tasks (larger, smarter for code)
#   OLLAMA_CHAT_MODEL  — for read/run tasks    (faster, cheaper for Q&A)
#
# Recommended setup:
#   ollama pull qwen2.5-coder:7b   ← coder model (~4.5 GB)
#   ollama pull llama3.2           ← chat model  (~2 GB)
#
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_CODER_MODEL=qwen2.5-coder:7b
# OLLAMA_CHAT_MODEL=llama3.2
#
# Override both with a single model (disables per-intent routing):
# OLLAMA_MODEL=qwen2.5-coder:7b
#
# OLLAMA_TOOLS=1
# OLLAMA_AGENT_MAX_TURNS=16
# OLLAMA_TEMPERATURE=0.1
# OLLAMA_NUM_CTX=16384
# OLLAMA_DISABLED=1

# ─── Google Gemini — free tier ────────────────────────────────────────────────
# Get key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ─── Groq — free tier ─────────────────────────────────────────────────────────
# Get key: https://console.groq.com
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant

# ─── Fallback behaviour ───────────────────────────────────────────────────────
# When Claude errors or hits quota, fallbacks run in order (Ollama = local Llama-class models).
# On Netlify/Vercel the default order is gemini,groq,ollama (cloud first; localhost Ollama won’t work).
# FALLBACK_ORDER=ollama,gemini,groq
# FALLBACK_TIMEOUT_MS=120000
# FALLBACK_VERBOSE_BANNER=1
